{
  "name": "xlsx-converter",
  "version": "1.2.0",
  "description": "Secure, zero-CVE XLS/XLSX/CSV/ODS/JSON conversion service. Pure-JS helpers + a tiny client SDK + a hardened Docker image.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./client": "./src/client/sdk.js",
    "./server": "./src/server/converter.js"
  },
  "files": [
    "src/index.js",
    "src/client/sdk.js",
    "src/server/converter.js",
    "src/server/index.js",
    "src/server/xls-conversion-service.py",
    "requirements.txt",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helloderekg/xls-converter.git"
  },
  "homepage": "https://github.com/helloderekg/xls-converter#readme",
  "bugs": {
    "url": "https://github.com/helloderekg/xls-converter/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node start-services.js",
    "start:python": "python src/server/xls-conversion-service.py",
    "start:node": "node src/server/index.js",
    "start:client": "python -m http.server 4001 --directory src/client",
    "docker:build": "docker build -t derekgsayshi/xls-converter:1.2.0 -t derekgsayshi/xls-converter:latest .",
    "docker:run": "docker run --rm -p 4040:4040 -p 5001:5001 -p 4001:4001 derekgsayshi/xls-converter:1.2.0",
    "docker:scan": "docker scout cves derekgsayshi/xls-converter:1.2.0"
  },
  "keywords": [
    "xls",
    "xlsx",
    "excel",
    "csv",
    "ods",
    "converter",
    "spreadsheet",
    "docker",
    "zero-cve",
    "chainguard",
    "wolfi"
  ],
  "author": "Derek G",
  "license": "MIT",
  "dependencies": {
    "cors": "2.8.5",
    "exceljs": "4.4.0",
    "express": "4.21.2",
    "form-data": "4.0.4",
    "jsonwebtoken": "9.0.2",
    "multer": "2.1.1",
    "node-fetch": "2.6.12"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.3",
    "supertest": "^7.1.1",
    "vitest": "^3.2.3"
  },
  "overrides": {
    "form-data": "4.0.4",
    "minimatch": "10.2.3",
    "@isaacs/brace-expansion": "5.0.1",
    "brace-expansion": "2.0.3",
    "qs": "6.14.2",
    "glob": "11.1.0",
    "picomatch": "4.0.4",
    "jws": "3.2.3",
    "path-to-regexp": "0.1.13",
    "tar": "7.5.11"
  }
}
